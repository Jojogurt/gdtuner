; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited just fine in a text editor.

[application]

config/name="gdtuner Example"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.3")

[autoload]

DebugTuner="*res://addons/gdtuner/debug_tuner.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/gdtuner/plugin.cfg")
